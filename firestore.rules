rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - The unique identifier for the user.
    //   - email: string (required) - The user's email address.
    //   - displayName: string (optional) - The user's display name.
    //   - completedQuestions: list (optional) - List of question IDs completed.
    //   - questionStatus: map (optional) - Status of each question (correct/incorrect).
    //   - bookmarkedQuestions: list (optional) - List of bookmarked question IDs.
    //   - accuracyHistory: list (optional) - History of accuracy over time.
    //   - accuracy: number (optional) - Overall accuracy percentage.
    //   - streak: number (optional) - Current daily streak.
    //   - lastAttemptDate: string (optional) - Date of the last question attempt.
    //   - totalCorrect: number (optional) - Total number of correct answers.
    //   - totalAttempted: number (optional) - Total number of questions attempted.
    //   - badges: list (optional) - List of earned badges.
    //   - updatedAt: string (optional) - Last time the progress was updated.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "bhavyakapatel2008@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('completedQuestions' in data) || data.completedQuestions is list) &&
             (!('questionStatus' in data) || data.questionStatus is map) &&
             (!('bookmarkedQuestions' in data) || data.bookmarkedQuestions is list) &&
             (!('accuracyHistory' in data) || data.accuracyHistory is list) &&
             (!('accuracy' in data) || data.accuracy is number) &&
             (!('streak' in data) || data.streak is number) &&
             (!('lastAttemptDate' in data) || data.lastAttemptDate is string) &&
             (!('totalCorrect' in data) || data.totalCorrect is number) &&
             (!('totalAttempted' in data) || data.totalAttempted is number) &&
             (!('badges' in data) || data.badges is list) &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
